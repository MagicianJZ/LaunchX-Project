{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "direct",
        "group"
      ],
      "default": "direct"
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "User IDs"
    },
    "participant_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "name": {
      "type": "string",
      "description": "Group chat name"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_time": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "participants"
  ]
}